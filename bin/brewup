#!/usr/bin/env perl
use strict;
use warnings;
use utf8;
use POSIX qw(strftime);

use FindBin;
use lib "$FindBin::Bin/lib";

use CLI::Arguments;
use CLI::Runner;

=head1 NAME

brewup - Update Homebrew and all installed packages

=head1 SYNOPSIS

    $ brewup --dry-run (or -n to only print commands without executing)
    $ brewup

=head1 DESCRIPTION

This script updates Homebrew and all installed packages. It checks if Homebrew is installed, and if not, it provides instructions on how to install it. Then it runs the following commands in sequence:
- brew update
- brew upgrade
- brew autoremove
- brew cleanup
Each command is executed with error handling, and the script prints timestamps and command information in color if the output is a terminal.

=cut

my $PATH = [ split(/:/, ($ENV{PATH} // q{})) ];
my $BREW_INSTALL_COMMAND = '/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"';
die "Homebrew is not installed.\nInstall it with:\n$BREW_INSTALL_COMMAND\n" unless grep {
    my $p = "$_/" . 'brew';
    -f $p && -x $p;
} @$PATH;

my $COMMANDS = [
    [qw(brew update)],
    [qw(brew upgrade -y --cask)],
    [qw(brew upgrade -y)],
    [qw(brew autoremove)],
    [qw(brew cleanup)],
];

my $runner = CLI::Runner->new;
my $arg_parser = CLI::Arguments->new(
    {
        name => 'dry-run',
        alias => 'n',
        description => 'Only print commands without executing',
    },
    {
        name => 'help',
        alias => 'h',
        description => 'Show this help message',
    }
);

my $args;
eval {
    $args = $arg_parser->parse(@ARGV);
};
if ($@) {
    die "Error parsing arguments: $@\nUse --help to see available options.\n";
}
if ($args->{'help'}) {
    print "Usage: brewup [options]\n\nOptions:\n";
    for my $arg (@{$arg_parser->{_args}}) {
        printf "  --%-10s -%s  %s\n", $arg->{name}, $arg->{alias} // '', $arg->{description};
    }
    exit 0;
}


for my $command (@{$COMMANDS}) {
    $runner->run($command, {
        print_command => 1,
        dry_run => $args->{ 'dry-run' },
    });
}
