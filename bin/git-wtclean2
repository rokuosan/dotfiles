#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  git wtclean           Show linked worktrees under ghq repositories that would be removed
  git wtclean -d        Remove them with `git worktree remove`
  git wtclean -D        Force remove them with `git worktree remove --force`
  git wtclean --prune   Prune stale worktree metadata with `git worktree prune`

Options:
  -d                    Remove worktrees with `git worktree remove`
  -D                    Force remove worktrees with `git worktree remove --force`
  --prune               Run `git worktree prune` for each ghq repository
  -v, --verbose         Print each repository while pruning
  -h                    Show this help

Note:
  When invoked as a Git subcommand, use `git wtclean -h`.
  `git wtclean --help` is handled by Git itself and opens the git-wtclean(1) man page.
USAGE
}

delete_flag=''
prune=false
verbose=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    -d|-D)
      if [ -n "$delete_flag" ]; then
        printf 'git wtclean: specify only one delete option: -d or -D\n' >&2
        usage >&2
        exit 2
      fi
      delete_flag="$1"
      ;;
    --prune)
      prune=true
      ;;
    -v|--verbose)
      verbose=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'git wtclean: unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

need_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'git wtclean: required command not found: %s\n' "$1" >&2
    exit 127
  fi
}

need_command ghq
need_command git

removed=0
found=0
failed=0
prune_checked=0

list_linked_worktrees() {
  git -C "$1" worktree list --porcelain |
    awk '
      BEGIN { RS = ""; FS = "\n" }
      NR == 1 { next }
      {
        path = ""
        bare = 0
        for (i = 1; i <= NF; i++) {
          if ($i == "bare") {
            bare = 1
          } else if ($i ~ /^worktree /) {
            path = substr($i, 10)
          }
        }
        if (!bare && path != "") {
          print path
        }
      }
    '
}

while IFS= read -r repo; do
  [ -n "$repo" ] || continue

  if ! git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
    continue
  fi

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    found=$((found + 1))

    if [ -z "$delete_flag" ]; then
      printf 'Would remove: %s\n' "$path"
    else
      printf 'Removing (%s): %s\n' "$delete_flag" "$path"
      if [ "$delete_flag" = "-D" ]; then
        remove_args=(--force "$path")
      else
        remove_args=("$path")
      fi

      if git -C "$repo" worktree remove "${remove_args[@]}"; then
        removed=$((removed + 1))
      else
        failed=$((failed + 1))
        printf 'git wtclean: failed to remove: %s\n' "$path" >&2
      fi
    fi
  done < <(list_linked_worktrees "$repo")

  if [ "$prune" = true ]; then
    if [ "$verbose" = true ]; then
      printf 'Pruning: %s\n' "$repo"
    fi
    if git -C "$repo" worktree prune; then
      prune_checked=$((prune_checked + 1))
    else
      failed=$((failed + 1))
      printf 'git wtclean: failed to prune: %s\n' "$repo" >&2
    fi
  fi
done < <(ghq list -p)

if [ -z "$delete_flag" ]; then
  if [ "$prune" = true ]; then
    printf 'Done. found=%d prune_checked=%d failed=%d\n' "$found" "$prune_checked" "$failed"
  else
    printf 'Dry run. found=%d. Run %s to remove, or %s to force remove.\n' "$found" "'git wtclean -d'" "'git wtclean -D'"
  fi
else
  printf 'Done. found=%d removed=%d prune_checked=%d failed=%d\n' "$found" "$removed" "$prune_checked" "$failed"
fi

if [ "$failed" -gt 0 ]; then
  exit 1
fi
